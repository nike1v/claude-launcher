{
  "name": "claude-launcher",
  "version": "0.1.17",
  "description": "Electron desktop app for running Claude CLI sessions",
  "repository": {
    "type": "git",
    "url": "https://github.com/nike1v/claude-launcher"
  },
  "main": "out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ELECTRON_OZONE_PLATFORM_HINT=auto electron-vite dev --noSandbox",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lexical/react": "^0.21.0",
    "electron-updater": "^6.8.3",
    "lexical": "^0.21.0",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "happy-dom": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "com.claude-launcher.app",
    "productName": "Claude Launcher",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "linux": {
      "artifactName": "${name}-${version}.${ext}",
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "artifactName": "${name}-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    }
  }
}
