<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron/V8 needs JIT and writable-executable memory under the
       hardened runtime that notarization requires. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- node-pty ships a native pty.node loaded into the app; disabling
       library validation lets nested/native code load without being
       co-signed by our Team ID. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- The launcher spawns claude via env-tweaked shells (PATH export for
       ssh/wsl); allow inherited processes to read DYLD_* / env vars. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
